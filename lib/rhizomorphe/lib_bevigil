import requests
import urllib3

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

def fetch_sub(domain):
    """
    Queries BeVigil OSINT API. 
    Finds subdomains extracted from mobile application packages.
    """
    results = set()
    try:
        # Endpoint public ne nécessitant pas de clé pour des requêtes basiques
        url = f"https://osint.bevigil.com/api/{domain}/subdomains/"
        r = requests.get(url, timeout=10, verify=False)
        if r.status_code == 200:
            data = r.json()
            if "subdomains" in data:
                for sub in data["subdomains"]:
                    if sub.endswith(domain):
                        results.add(sub.lower())
    except:
        pass
    return list(results)
